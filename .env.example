# Strato FTP/SFTP Zugangsdaten — KOPIEREN zu .env (gitignored).
# Diese Werte stehen im Strato-Kundenpanel unter "FTP/SFTP" oder "Webspace".

# FTP-Hostname, z.B. ssh.strato.de oder dein Domain-Name
STRATO_HOST=ssh.strato.de

# FTP-Benutzername (bei Strato meist die Domain selbst, z.B. fahrschule-nicolai.de)
STRATO_USER=fahrschule-nicolai.de

# FTP-Passwort (Strato-Hauptpasswort oder dediziertes FTP-Passwort)
STRATO_PASS=

# SSH-Port (22 für SFTP, 21 für FTP)
STRATO_PORT=22

# Protokoll: sftp (empfohlen) oder ftp
STRATO_PROTOCOL=sftp

# Remote Webroot — der Pfad auf dem Strato-Server zur Webseite.
# Üblicherweise /www, /htdocs oder einfach /
STRATO_REMOTE_PATH=/
